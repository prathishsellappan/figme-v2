# Firebase Config
# Get these from your Firebase Console → Project Settings → Your Apps
VITE_APIKEY=your_firebase_api_key
VITE_AUTHDOMAIN=your_project_id.firebaseapp.com
VITE_PROJECTID=your_firebase_project_id
VITE_STORAGEBUCKET=your_project_id.appspot.com
VITE_MESSAGINGSENDERID=your_messaging_sender_id
VITE_APPID=your_firebase_app_id

# Liveblocks Config
# Get this from your Liveblocks Dashboard → API Keys → Public Key
VITE_LIVEBLOCK_API=pk_your_liveblocks_public_key
